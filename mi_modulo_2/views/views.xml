<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_finance_report_audit_tree" model="ir.ui.view">
            <field name="name">finance.report.audit.tree</field>
            <field name="model">finance.report.audit</field>
            <field name="arch" type="xml">
                <list string="Logs de Auditoría Financiera" create="false" edit="false">
                    <field name="consultation_datetime"/>
                    <field name="user_id" widget="many2one_avatar_user"/> 
                    <field name="company_id"/>
                    <field name="net_amount" decoration-bf="1"/> <field name="alert_level" widget="badge" decoration-danger="alert_level == 'danger'" decoration-success="alert_level == 'success'"/>
                </list>
            </field>
        </record>

        <record id="view_finance_report_audit_form" model="ir.ui.view">
            <field name="name">finance.report.audit.form</field>
            <field name="model">finance.report.audit</field>
            <field name="arch" type="xml">
                <form string="Detalle de Consulta">
                    <sheet>
                        <group>
                            <group string="Información de Acceso">
                                <field name="consultation_datetime"/>
                                <field name="user_id"/>
                                <field name="company_id"/>
                            </group>
                            <group string="Métricas Capturadas">
                                <field name="net_amount"/>
                                <field name="alert_level"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_finance_report_audit" model="ir.actions.act_window">
            <field name="name">Auditoría de Consultas Gráficas</field>
            <field name="res_model">finance.report.audit</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_finance_report_audit" 
                  name="Historial de Consultas (Auditoría)" 
                  parent="mn_finance_insights.menu_finance_insights_root" 
                  action="action_finance_report_audit" 
                  sequence="100"/>

    </data>
</odoo>