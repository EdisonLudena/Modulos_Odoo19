<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="view_mail_activity_form_inherit_custom" model="ir.ui.view">
            <field name="name">mail.activity.schedule.form.inherit.custom</field>
            <field name="model">mail.activity.schedule</field>
            <field name="inherit_id" ref="mail.mail_activity_schedule_view_form"/>
            <field name="priority" eval="25"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_deadline']" position="after">
                    <field name="team_id"/>
                    <field name="allowed_user_ids" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='activity_user_id']" position="attributes">
                    <attribute name="domain">team_id and [('id', 'in', allowed_user_ids)] or []</attribute>
                    <attribute name="readonly">team_id</attribute>
                    <attribute name="force_save">1</attribute>
                </xpath>
            </field>
        </record>
</odoo>