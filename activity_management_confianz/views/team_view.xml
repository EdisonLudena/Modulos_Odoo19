<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="view_team_teams_form" model="ir.ui.view">
        <field name="name">team.teams.form</field>
        <field name="model">team.teams</field>
        <field name="arch" type="xml">
            <form string="Team">
                <sheet>
                    <!-- Stat Button -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_activities"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list-alt">

                            <field name="activity_count"
                                   widget="statinfo"
                                   string="Activities"/>
                        </button>
                    </div>

                    <!-- Title -->
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" required="1"/>
                        </h1>
                    </div>

                    <!-- Main Fields -->
                    <group>
                        <group>
                            <field name="team_leader" required="1"/>
                            <field name="activity_count" invisible="1"/>
                        </group>
                    </group>

                    <!-- Notebook -->
                    <notebook>
                        <!-- Members Page -->
                        <page string="Members" name="members">
                            <field name="member_ids" mode="kanban" class="w-100">
                                <kanban>
                                    <field name="name"/>
                                    <field name="email"/>
                                    <field name="phone"/>
                                    <field name="avatar_128"/>
                                    <templates>
                                        <t t-name="card" class="flex-row">
                                            <aside class="o_kanban_aside_full">
                                                <field name="avatar_128"
                                                       widget="image"
                                                       alt="Contact image"
                                                       options="{'img_class': 'object-fit-contain'}"/>
                                            </aside>
                                            <main class="ps-2">
                                                <div class="mb-1">
                                                    <field name="name" class="mb-0 fw-bold fs-5"/>
                                                </div>
                                                <div t-if="record.email.raw_value" class="text-truncate">
                                                    <i class="fa fa-fw me-1 fa-envelope text-primary" title="Email"/>
                                                    <field name="email"/>
                                                </div>
                                                <div t-if="record.phone.raw_value">
                                                    <i class="fa fa-fw me-1 fa-phone text-primary" title="Phone"/>
                                                    <field name="phone"/>
                                                </div>
                                            </main>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>

                        <!-- Notes Page -->
                        <page string="Notes" name="notes">
                            <group>
                                <field name="note"
                                       nolabel="1"
                                       placeholder="Notes..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_team_teams_list" model="ir.ui.view">
        <field name="name">team.teams.list</field>
        <field name="model">team.teams</field>
        <field name="arch" type="xml">

            <list string="Teams">
                <field name="name"/>
                <field name="team_leader"/>
            </list>

        </field>
    </record>

    <!-- ACTION -->
    <record id="action_team_teams" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">team.teams</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Team!
            </p>
        </field>

    </record>

    <!-- MENU -->
    <menuitem id="team_teams_menu"
              name="Teams"
              parent="activity_management_confianz.configuration_menu"
              action="action_team_teams"
              sequence="1"/>

</odoo>